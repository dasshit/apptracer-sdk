{
  "name": "@ddastter/apptracer-sdk",
  "version": "0.1.9",
  "description": "AppTracer SDK for React Native / Expo",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/dasshit/apptracer-sdk.git"
  },
  "main": "dist/index.cjs",
  "module": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "require": "./dist/index.cjs",
      "import": "./dist/index.js"
    },
    "./react-native-logs": {
      "types": "./dist/integrations/react-native-logs.d.ts",
      "require": "./dist/integrations/react-native-logs.cjs",
      "import": "./dist/integrations/react-native-logs.js"
    }
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "sideEffects": false,
  "scripts": {
    "build": "tsup",
    "prepublishOnly": "pnpm run build",
    "changeset": "changeset",
    "version-packages": "changeset version",
    "release": "changeset publish",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:ci": "jest --runInBand"
  },
  "publishConfig": {
    "access": "public"
  },
  "peerDependencies": {
    "react": ">=18",
    "react-native": ">=0.70"
  },
  "devDependencies": {
    "@changesets/cli": "^2.30.0",
    "@types/jest": "^30.0.0",
    "@types/node": "^25.6.0",
    "jest": "^30.3.0",
    "react-native-logs": "^5.6.0",
    "ts-jest": "^29.4.9",
    "ts-node": "^10.9.2",
    "tsup": "^8.5.1",
    "typescript": "^6.0.3"
  },
  "dependencies": {
    "@react-native-async-storage/async-storage": "^3.0.2"
  }
}